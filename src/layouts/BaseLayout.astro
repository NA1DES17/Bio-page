---
import HeadSEO from '@components/seo/HeadSEO.astro';
import Navbar from '@components/layout/Navbar.astro';
import Footer from '@components/layout/Footer.astro';
import '@styles/global.css';
import type { SEOMetadata } from '@config/seo';

export interface Props extends SEOMetadata {
  currentPath?: string;
  children?: import('astro/types').RenderTemplateResult;
}

const { currentPath = '', children, ...seo } = Astro.props;
---

<HeadSEO {...seo}>
  <Fragment slot="body">
    <Navbar currentPath={currentPath} />
    <main id="main-content" class="pt-16 sm:pt-20 min-h-screen">
      <slot />
    </main>
    <Footer />
  </Fragment>
</HeadSEO>
