---
import { SITE } from '@config/site';
import { HEADER_NAV } from '@config/navigation';
import { SITE_SETTINGS } from '@data/settings';
import Container from '@components/ui/Container.astro';
import Icon from '@components/ui/Icon.astro';
import { getButtonClasses } from '@components/ui/Button.tsx';

export interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
const settings = SITE_SETTINGS.navbar;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-md border-b border-surface-container overflow-x-hidden">
  <Container>
    <nav class="flex items-center justify-between h-16 sm:h-20" aria-label="Navegación principal">
      <a href="/" class="flex items-center gap-2" aria-label={SITE.name}>
        <img src="/logobio.png" alt={SITE.name} class="h-12 w-auto max-w-[120px] sm:max-w-none" />
        <span class="hidden sm:inline font-heading text-lg font-medium tracking-tight text-on-surface">{SITE.name}</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {
          HEADER_NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'px-3 py-2 text-sm rounded-default transition-colors duration-200 font-body',
                  currentPath === item.href || currentPath.startsWith(item.href + '/')
                    ? 'text-primary bg-primary/10'
                    : 'text-on-surface-variant hover:text-on-surface hover:bg-surface-container',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Desktop CTA -->
      <a
        href={settings.cta.href}
        class="hidden md:inline-flex items-center justify-center gap-2 font-body font-medium rounded-full px-6 py-3 text-base bg-primary text-on-primary hover:bg-primary-container active:bg-primary-fixed-dim transition-all duration-300 hover:scale-[1.02] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        {settings.cta.label}
        <Icon name="arrow-right" size="sm" />
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        class="md:hidden p-2 text-on-surface-variant hover:text-on-surface transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        <span data-menu-icon-open><Icon name="menu" /></span>
        <span data-menu-icon-close class="hidden"><Icon name="close" /></span>
      </button>
    </nav>

    <!-- Mobile Menu Panel -->
    <div class="md:hidden hidden bg-surface border-t border-surface-container" data-mobile-menu>
      <div class="py-4 space-y-1 px-4 sm:px-8">
        {HEADER_NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block px-4 py-2.5 text-sm font-body rounded-default transition-colors duration-200',
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-primary bg-primary/10'
                : 'text-on-surface-variant hover:text-on-surface hover:bg-surface-container',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </Container>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  const iconOpen = document.querySelector('[data-menu-icon-open]');
  const iconClose = document.querySelector('[data-menu-icon-close]');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      toggle.setAttribute('aria-label', expanded ? 'Abrir menú' : 'Cerrar menú');
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Abrir menú');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      });
    });
  }
</script>
