---
export interface Props {
  name: 'leaf' | 'heart' | 'sparkles' | 'star' | 'check' | 'arrow-right' | 'menu' | 'close' | 'whatsapp' | 'instagram' | 'mail' | 'phone' | 'quote';
  size?: 'sm' | 'md' | 'lg';
