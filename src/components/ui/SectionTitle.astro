---
import { cn } from '@utils/cn';

export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, title, subtitle, align = 'center', class: className } = Astro.props;
---

<div
  class:list={[
    cn('max-w-2xl', align === 'center' && 'mx-auto text-center', className),
  ]}
>
  {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
  <h2 class="text-[clamp(1.75rem,5vw,2.5rem)] font-heading leading-tight text-balance">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg text-on-surface-variant leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
