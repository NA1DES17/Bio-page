---
import { SITE } from '@config/site';
import {
  formatMetaTitle,
  resolveCanonical,
  buildBreadcrumbSchema,
  buildOpenGraph,
  buildTwitterCard,
  buildLocalBusinessSchema,
} from '@utils/metadata';
import type { SEOMetadata, BreadcrumbItem } from '@config/seo';

export interface Props extends SEOMetadata {
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  canonical,
  noindex,
  nofollow,
  openGraph,
  breadcrumbs,
  schema: extraSchema,
} = Astro.props;

const resolvedTitle = formatMetaTitle(title);
const resolvedCanonical = resolveCanonical(canonical ?? Astro.url.pathname);
const robots = [
  noindex && 'noindex',
  nofollow && 'nofollow',
]
  .filter(Boolean)
  .join(',') || 'index, follow';

const schemas: Record<string, unknown>[] = [buildLocalBusinessSchema()];

if (breadcrumbs && breadcrumbs.length > 0) {
  schemas.push(buildBreadcrumbSchema(breadcrumbs));
}

if (extraSchema) {
  schemas.push(...extraSchema);
}
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{resolvedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <meta name="robots" content={robots} />

    <!-- OpenGraph -->
    {
      Object.entries(buildOpenGraph(openGraph ?? { title, description }, Astro.url.pathname)).map(
        ([prop, value]) => <meta property={prop} content={String(value)} />,
      )
    }

    <!-- Twitter -->
    {
      Object.entries(
        buildTwitterCard(resolvedTitle, description, openGraph?.ogImage),
      ).map(([name, value]) => <meta name={name} content={String(value)} />)
    }

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preload fonts -->
    <link
      rel="preload"
      href="/fonts/manrope-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/libre-caslon-text-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Schema.org -->
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <slot />
  </head>
  <body>
    <slot name="body" />
  </body>
</html>
