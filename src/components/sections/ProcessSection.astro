---
import Container from '@components/ui/Container.astro';
import SectionTitle from '@components/ui/SectionTitle.astro';
import Icon from '@components/ui/Icon.astro';

interface Step {
  step: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  steps: Step[];
}
---

<section class="section-padding">
  <Container width="narrow">
    <SectionTitle eyebrow={Astro.props.eyebrow} title={Astro.props.title} subtitle={Astro.props.subtitle} />

    <div class="mt-12 space-y-8">
      {Astro.props.steps.map((step, idx) => (
        <div class="flex gap-6 items-start group">
          <span class="shrink-0 font-heading text-3xl sm:text-4xl text-primary/40 group-hover:text-primary transition-colors leading-none">
            {step.step}
          </span>
          <div class="pt-1">
            <h3 class="text-lg font-heading text-on-surface mb-2">{step.title}</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">{step.description}</p>
          </div>
          {idx < Astro.props.steps.length - 1 && (
            <div class="hidden sm:block absolute left-[1.15rem] top-12 bottom-0 w-px bg-surface-container-high" aria-hidden="true" />
          )}
        </div>
      ))}
    </div>
  </Container>
</section>
