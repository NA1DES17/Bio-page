---
import Container from '@components/ui/Container.astro';
import SectionTitle from '@components/ui/SectionTitle.astro';
import { SITE_SETTINGS } from '@data/settings';
import { SITE } from '@config/site';
import Icon from '@components/ui/Icon.astro';
import { getButtonClasses } from '@components/ui/Button.tsx';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}
---

<section class="section-padding bg-surface-container-low">
  <Container>
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <div>
        <SectionTitle
          eyebrow={Astro.props.eyebrow}
          title={Astro.props.title}
          subtitle={Astro.props.subtitle}
          align="left"
        />

        <div class="mt-8 space-y-6">
          <a
            href={`https://wa.me/${SITE.authorPhone.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(SITE_SETTINGS.whatsapp.message)}`}
            class={getButtonClasses({ variant: 'primary', size: 'lg' })}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="whatsapp" size="sm" />
            {SITE_SETTINGS.whatsapp.buttonLabel}
          </a>

          <div class="flex items-center gap-4 text-sm text-on-surface-variant">
            <span class="flex items-center gap-2">
              <Icon name="mail" size="sm" />
              {SITE.authorEmail}
            </span>
          </div>
        </div>
      </div>

      <!-- Form -->
      <form class="space-y-5" action="#" method="POST" data-form-contact>
        <div>
          <label for="contact-name" class="eyebrow block mb-2">Nombre</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            class="w-full px-4 py-3 rounded-default bg-surface-container border border-outline-variant text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:border-secondary transition-colors"
            placeholder="Tu nombre"
          />
        </div>
        <div>
          <label for="contact-email" class="eyebrow block mb-2">Email</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            required
            class="w-full px-4 py-3 rounded-default bg-surface-container border border-outline-variant text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:border-secondary transition-colors"
            placeholder="tu@email.com"
          />
        </div>
        <div>
          <label for="contact-message" class="eyebrow block mb-2">Mensaje</label>
          <textarea
            id="contact-message"
            name="message"
            rows={4}
            required
            class="w-full px-4 py-3 rounded-default bg-surface-container border border-outline-variant text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:border-secondary transition-colors resize-y"
            placeholder="Contame en qué te gustaría que te acompañe..."
          ></textarea>
        </div>
        <button type="submit" class={getButtonClasses({ variant: 'primary', size: 'lg' })}>
          Enviar mensaje
        </button>
      </form>
    </div>
  </Container>
</section>
