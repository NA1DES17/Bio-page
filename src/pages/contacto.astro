---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactSection from '@components/sections/ContactSection.astro';

const breadcrumbs = [
  { label: 'Inicio', path: '/' },
  { label: 'Contacto', path: '/contacto' },
];
---

<BaseLayout
  title="Contacto — Alma en Calma"
  description="Contactame para consultar sobre sesiones de biodescodificación online. Respondo todas tus dudas sin compromiso."
  currentPath="/contacto"
  breadcrumbs={breadcrumbs}
>
  <section class="section-padding pb-0">
    <div class="container-narrow">
      <p class="eyebrow mb-4">Contacto</p>
      <h1 class="text-[clamp(2rem,5vw,3rem)] font-heading leading-tight text-balance mb-6">
        Estoy acá para escucharte
      </h1>
      <p class="text-lg text-on-surface-variant leading-relaxed max-w-2xl">
        Si tenés dudas, querés saber más sobre las sesiones o simplemente necesitás
        conversar antes de dar el primer paso, escribime. Sin compromiso.
      </p>
    </div>
  </section>

  <ContactSection title="Escribime y te respondo" />
</BaseLayout>
