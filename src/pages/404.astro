---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getButtonClasses } from '@components/ui/Button.tsx';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que buscas no existe. Volvé al inicio para encontrar lo que necesitas."
  noindex
  nofollow
>
  <section class="section-padding min-h-[60vh] flex items-center">
    <div class="container-narrow text-center">
      <p class="font-heading text-8xl text-primary/30 mb-4">404</p>
      <h1 class="text-3xl font-heading text-on-surface mb-4">
        Página no encontrada
      </h1>
      <p class="text-lg text-on-surface-variant mb-8 max-w-md mx-auto">
        La página que buscás no existe o fue movida. Volvé al inicio para encontrar lo que necesitás.
      </p>
      <a href="/" class={getButtonClasses({ variant: 'primary', size: 'lg' })}>
        Volver al inicio
      </a>
    </div>
  </section>
</BaseLayout>
